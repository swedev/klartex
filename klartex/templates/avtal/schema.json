{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Avtal",
  "description": "Avtal / Agreement — composable block-based format",
  "type": "object",
  "required": ["title", "party1", "party2", "body"],
  "definitions": {
    "party": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "description": "Party name (company or person)" },
        "org_number": { "type": "string", "description": "Organization number (for companies)" },
        "id_number": { "type": "string", "description": "Personal identity number (for individuals)" },
        "address": { "type": "string", "description": "Full address as a single line" },
        "address_line1": { "type": "string", "description": "Street address" },
        "address_line2": { "type": "string", "description": "Postal code and city" },
        "signatory": { "type": "string", "description": "Name of person signing" }
      }
    }
  },
  "properties": {
    "header": { "type": "string", "enum": ["standard", "minimal", "none"], "default": "standard", "description": "Header layout" },
    "title": { "type": "string", "description": "Agreement title" },
    "lang": { "type": "string", "default": "sv", "description": "sv or en" },
    "party1": { "$ref": "#/definitions/party" },
    "party2": { "$ref": "#/definitions/party" },
    "body": {
      "type": "array",
      "description": "Ordered list of document blocks",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["title_page"] }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["parties"] },
              "label1": { "type": "string", "default": "Part 1", "description": "Label for party 1 fieldset" },
              "label2": { "type": "string", "default": "Part 2", "description": "Label for party 2 fieldset" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "text"],
            "properties": {
              "type": { "type": "string", "enum": ["heading"] },
              "text": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "text"],
            "properties": {
              "type": { "type": "string", "const": "text" },
              "text": { "type": "string" }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "number"],
            "anyOf": [
              { "required": ["text"] },
              { "required": ["content"] }
            ],
            "properties": {
              "type": { "type": "string", "enum": ["clause"] },
              "number": { "type": "string", "minLength": 1 },
              "text": { "type": "string" },
              "level": { "type": "integer", "enum": [2, 3, 4] },
              "content": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["type"]
                }
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["signatures"] },
              "new_page": { "type": "boolean", "default": true, "description": "Start signatures on a new page" }
            },
            "additionalProperties": false
          }
        ]
      },
      "minItems": 1
    }
  }
}
