{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://klartex.se/schemas/blocks/columns/v0.1",
  "title": "Columns Block",
  "description": "Side-by-side layout container. Holds 1-4 column-stacks; each stack is rendered as a vertical sequence of blocks in its own column at equal width.",
  "type": "object",
  "required": ["type", "items"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "columns" },
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "description": "Each entry is a non-empty array of blocks rendered as a single column.",
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "heading",
                "text",
                "list",
                "callout",
                "quote",
                "table",
                "latex",
                "form",
                "description_list"
              ],
              "description": "Allowed nested block types. Top-only types and columns itself are rejected."
            }
          }
        }
      }
    }
  }
}
