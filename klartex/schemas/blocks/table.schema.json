{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://klartex.se/schemas/blocks/table/v0.1",
  "title": "Table Block",
  "description": "Simple data table with header and rows. Cells pass through inline markup.",
  "type": "object",
  "required": ["type", "header", "rows"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "table" },
    "header": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "description": "Header row cells"
    },
    "rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "array",
        "items": { "type": "string" }
      },
      "description": "Body rows. Each row should have the same number of cells as the header."
    },
    "columns": {
      "type": "array",
      "description": "Optional per-column hints (width, alignment). Same length as header.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "width": {
            "type": "string",
            "description": "Fixed LaTeX dimension (e.g. '3.4cm') or 'fill' for tabularx X-column"
          },
          "align": {
            "type": "string",
            "enum": ["left", "right", "center"],
            "default": "left"
          }
        }
      }
    },
    "size": {
      "type": "string",
      "enum": ["normal", "small", "footnotesize"],
      "default": "small"
    }
  }
}
