{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://klartex.se/schemas/blocks/list/v0.1",
  "title": "List Block",
  "description": "Bullet or numbered list, optionally nested. Items pass through inline markup.",
  "type": "object",
  "required": ["type", "items"],
  "additionalProperties": false,
  "properties": {
    "type": { "type": "string", "const": "list" },
    "style": {
      "type": "string",
      "enum": ["bullet", "numbered"],
      "default": "bullet",
      "description": "Outer list style"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "description": "Items: strings (leaves) or objects with text + nested items",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["text", "items"],
            "additionalProperties": false,
            "properties": {
              "text": { "type": "string" },
              "items": { "type": "array", "minItems": 1 },
              "style": {
                "type": "string",
                "enum": ["bullet", "numbered"],
                "description": "Override style for nested list (defaults to parent's style)"
              }
            }
          }
        ]
      }
    }
  }
}
